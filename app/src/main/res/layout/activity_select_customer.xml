<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackSelectCustomer"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_rounded_icon"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="8dp"
            app:tint="@color/text_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chọn khách đặt phòng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <!-- Search -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="14dp">
        <EditText
            android:id="@+id/etSearch"
            style="@style/FormInput"
            android:layout_height="40dp"
            android:hint="Tìm theo tên, CCCD, SĐT..."
            android:textSize="13sp"
            android:paddingStart="38dp"
            android:layout_marginTop="0dp"
            android:background="@drawable/bg_input"
            android:singleLine="true" />
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_search_small"
            app:tint="#b0ab9e" />
    </FrameLayout>

    <!-- Customer List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCustomers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="18dp"
        android:clipToPadding="false"/>

    <!-- Bottom Action -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:background="@color/page_bg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddNewCustomer"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="KHÁCH MỚI"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#7a7568"
            app:backgroundTint="#0D000000"
            app:cornerRadius="12dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="CHỌN"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#9a7340"
            app:cornerRadius="12dp"
            app:elevation="0dp" />
    </LinearLayout>

</LinearLayout>

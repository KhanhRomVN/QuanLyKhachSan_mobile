<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackStaffDetail"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_rounded_icon"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="8dp"
            app:tint="@color/text_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btnBackStaffDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chi tiết nhân viên"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1a1810" />

            <TextView
                android:id="@+id/tvStaffId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID #1"
                android:textSize="12sp"
                android:textColor="#7a7568" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbarThumbVertical="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="24dp">

            <!-- Hero Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    
                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_marginEnd="18dp">
                        <View
                            android:id="@+id/viewHeroAvatarBg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_status_badge" />
                        <TextView
                            android:id="@+id/tvHeroAvatarInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="LAN"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvHeroName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nguyễn Thị Lan"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1a1810"
                            android:layout_marginBottom="6dp" />
                        <TextView
                            android:id="@+id/tvHeroRoleBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_badge"
                            android:backgroundTint="#1A9a7340"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="Trưởng ca"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#9a7340" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Info Sections -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN CƠ BẢN"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#b0ab9e"
                android:letterSpacing="0.08"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/card_bg"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <include layout="@layout/view_info_row" android:id="@+id/rowRole" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0D000000" android:layout_marginHorizontal="16dp" />
                    <include layout="@layout/view_info_row" android:id="@+id/rowPhone" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0D000000" android:layout_marginHorizontal="16dp" />
                    <include layout="@layout/view_info_row" android:id="@+id/rowEmail" />
                    <View android:id="@+id/divPassword" android:layout_width="match_parent" android:layout_height="1dp" android:background="#0D000000" android:layout_marginHorizontal="16dp" />
                    <include layout="@layout/view_info_row" android:id="@+id/rowPassword" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/layoutAdminActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:background="#FAFAFA">
        <Button
            android:id="@+id/btnEditStaff"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Chỉnh sửa"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#9a7340"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            android:elevation="4dp" />
        <Button
            android:id="@+id/btnDeleteStaff"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Xoá nhân viên"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#1A000000"
            android:textColor="#7a7568"
            app:strokeColor="#1A000000"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="0dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/card_bg"
        app:strokeColor="@color/card_border"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Top row: room number + type -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Room number badge (square) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardRoomBadge"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/status_vacant_bg">
                    <TextView
                        android:id="@+id/tvRoomNumber"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="101"
                        android:textColor="@color/status_vacant_text"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:gravity="center"/>
                </androidx.cardview.widget.CardView>

                <!-- Room type info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:id="@+id/tvRoomType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đơn"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                    <TextView
                        android:id="@+id/tvMaxGuests"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tối đa 1 người"
                        android:textSize="10sp"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Middle: Guests or empty indicator -->
            <LinearLayout
                android:id="@+id/layoutGuests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="-2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvGuestNames"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nguyễn Văn An +2"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:ellipsize="end"
                        android:maxLines="1"/>
                    <TextView
                        android:id="@+id/tvStayDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="22/03 → 25/03 · 3 đêm"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAvatars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutEmptyIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:alpha="0.5">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"/>
                <TextView
                    android:id="@+id/tvEmptyMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phòng đang trống, sẵn sàng nhận khách"
                    android:textSize="11sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Bottom row: amenities + price -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:id="@+id/layoutAmenities"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    <TextView
                        android:id="@+id/tvRoomPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="650K/đêm"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Status badge overlay - top right corner, no padding -->
    <TextView
        android:id="@+id/tvStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:background="@drawable/bg_status_vacant"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Trống"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"/>

</FrameLayout>

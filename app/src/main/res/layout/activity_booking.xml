<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBackBooking"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_rounded_icon"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="8dp"
            app:tint="@color/text_gray" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đặt phòng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="24dp">

            <!-- Room Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN PHÒNG"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="10dp"/>
                    <TextView
                        android:id="@+id/tvRoomInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phòng 101 · Đơn"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>
                    <TextView
                        android:id="@+id/tvRoomPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="650.000 VNĐ/đêm"
                        android:textSize="13sp"
                        android:textColor="@color/accent"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Customer Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KHÁCH ĐẶT"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="10dp"/>
                    <LinearLayout
                        android:id="@+id/layoutCustomerCards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Check-in Date -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NHẬN PHÒNG"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="10dp"/>
                    <LinearLayout
                        android:id="@+id/layoutCheckIn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_input"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvCheckInDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hôm nay"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Number of Nights -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SỐ ĐÊM Ở"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="10dp"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDecreaseNights"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:icon="@drawable/ic_minus"
                            app:iconTint="@color/text_primary"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/card_bg"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"/>
                        <TextView
                            android:id="@+id/tvNights"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:gravity="center"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnIncreaseNights"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:icon="@drawable/ic_plus"
                            app:iconTint="@color/text_primary"
                            app:iconGravity="textStart"
                            app:backgroundTint="@color/card_bg"
                            app:strokeColor="@color/card_border"
                            app:strokeWidth="1dp"
                            app:cornerRadius="10dp"
                            android:padding="0dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Check-out Date Preview -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="@color/card_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TRẢ PHÒNG DỰ KIẾN"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_gray"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="10dp"/>
                    <TextView
                        android:id="@+id/tvCheckOutDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày mai"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Total Price -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/accent"
                app:strokeColor="@color/accent_border"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỔNG CỘNG"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="0.07"
                            android:alpha="0.8"/>
                        <TextView
                            android:id="@+id/tvTotalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="650.000 VNĐ"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvPriceDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 đêm × 650K"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:alpha="0.7"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Confirm Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:background="@color/white">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Xác nhận đặt phòng"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"/>
    </LinearLayout>

</LinearLayout>

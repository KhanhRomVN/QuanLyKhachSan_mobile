<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="18dp">

        <ImageButton
            android:id="@+id/btnBackForm"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_rounded_icon"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="8dp"
            app:tint="@color/text_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btnBackForm"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm nhân viên"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1a1810" />

            <TextView
                android:id="@+id/tvFormSubTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điền đầy đủ thông tin"
                android:textSize="12sp"
                android:textColor="#7a7568" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbarThumbVertical="@null">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="24dp">

            <!-- Thông tin cơ bản -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D000000">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN CƠ BẢN"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#b0ab9e"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp" />
                    
                    <TextView style="@style/FormLabel" android:text="Họ và tên *" />
                    <EditText android:id="@+id/etStaffNameForm" style="@style/FormInput" android:hint="Nguyễn Văn A" />

                    <TextView style="@style/FormLabel" android:text="Số điện thoại" android:layout_marginTop="12dp" />
                    <EditText android:id="@+id/etStaffPhoneForm" style="@style/FormInput" android:hint="0901234567 (tùy chọn)" android:inputType="phone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tài khoản -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D000000">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TÀI KHOẢN ĐĂNG NHẬP"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#b0ab9e"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp" />
                    
                    <TextView style="@style/FormLabel" android:text="Email *" />
                    <EditText android:id="@+id/etStaffEmailForm" style="@style/FormInput" android:hint="ten@hotel.com" android:inputType="textEmailAddress" />

                    <TextView android:id="@+id/tvPassLabel" style="@style/FormLabel" android:text="Mật khẩu *" android:layout_marginTop="12dp" />
                    <EditText android:id="@+id/etStaffPasswordForm" style="@style/FormInput" android:hint="••••••••" android:inputType="textPassword" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Phân công -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0D000000">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHÂN CÔNG"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#b0ab9e"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp" />
                    
                    <TextView style="@style/FormLabel" android:text="Chức vụ" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleStaff"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:text="Nhân viên"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="36dp"
                            app:cornerRadius="12dp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRoleAdmin"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="5dp"
                            android:text="Admin"
                            android:textSize="13sp"
                            android:textAllCaps="false"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="36dp"
                            app:cornerRadius="12dp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>
    
    <!-- Buttons fixed at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="18dp"
        android:background="@color/page_bg">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="Hủy"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:backgroundTint="#0D000000"
            android:textColor="#7a7568"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            app:elevation="0dp"
            app:cornerRadius="12dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveStaff"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="Tạo tài khoản"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:backgroundTint="#9a7340"
            android:textColor="#FFFFFF"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            app:elevation="0dp"
            app:cornerRadius="12dp" />
    </LinearLayout>

</LinearLayout>

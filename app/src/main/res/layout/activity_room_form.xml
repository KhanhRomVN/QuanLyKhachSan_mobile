                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRobe"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Áo choàng"
                            app:chipBackgroundColor="@color/bg_chip_amenity"
                            app:chipStrokeColor="#1A000000"
                            app:chipStrokeWidth="1dp"
                            app:chipCornerRadius="8dp"
                            app:checkedIconVisible="false"
                            app:chipMinTouchTargetSize="0dp"
                            android:minHeight="28dp"
                            android:textSize="11sp"
                            app:chipStartPadding="4dp"
                            app:chipEndPadding="4dp"
                            android:textColor="@color/text_chip_amenity" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipToiletries"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đồ vệ sinh"
                            app:chipBackgroundColor="@color/bg_chip_amenity"
                            app:chipStrokeColor="#1A000000"
                            app:chipStrokeWidth="1dp"
                            app:chipCornerRadius="8dp"
                            app:checkedIconVisible="false"
                            app:chipMinTouchTargetSize="0dp"
                            android:minHeight="28dp"
                            android:textSize="11sp"
                            app:chipStartPadding="4dp"

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@drawable/bg_rounded_icon"
            android:src="@drawable/ic_arrow_right"
            android:rotation="180"
            android:padding="8dp"
            app:tint="@color/text_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvFormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thêm phòng mới"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1a1810" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điền thông tin phòng đơn giản"
                android:textSize="12sp"
                android:textColor="#7a7568" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="24dp">

            <!-- Basic Info Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0A000000">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG TIN CƠ BẢN"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#b0ab9e"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView style="@style/FormLabel" android:text="SỐ PHÒNG *" />
                        <EditText android:id="@+id/etRoomNumber" style="@style/FormInput" android:inputType="text" android:hint="Vd: 101" />
                    </LinearLayout>
 
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginTop="12dp">
                        <TextView style="@style/FormLabel" android:text="LOẠI PHÒNG" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="5dp">
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeSingle"
                                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="2dp"
                                android:text="Phòng đơn"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="36dp"
                                app:cornerRadius="12dp" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeDouble"
                                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginHorizontal="2dp"
                                android:text="Phòng đôi"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="36dp"
                                app:cornerRadius="12dp" />
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTypeQuad"
                                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="2dp"
                                android:text="Phòng 4 người"
                                android:textSize="12sp"
                                android:textAllCaps="false"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="36dp"
                                app:cornerRadius="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Specs Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#0A000000">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THÔNG SỐ PHÒNG"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#b0ab9e"
                        android:letterSpacing="0.07"
                        android:layout_marginBottom="12dp" />

                    <TextView style="@style/FormLabel" android:text="GIÁ / ĐÊM (VNĐ) *" />
                    <EditText android:id="@+id/etPrice" style="@style/FormInput" android:inputType="number" android:hint="Vd: 500000" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Amenities Section -->

<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Muzi" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <item name="android:statusBarColor">@color/page_bg</item>
        <item name="android:windowBackground">@color/page_bg</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_gray</item>
        <item name="android:fontFamily">@font/dm_sans_family</item>
        
        <item name="colorControlNormal">#7a7568</item>
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorControlHighlight">#269a7340</item>
        <item name="colorAccent">@color/primary</item>
        
        <item name="materialButtonStyle">@style/RoundedButton</item>
        <item name="editTextStyle">@style/FormInput</item>
        <item name="android:editTextStyle">@style/FormInput</item>
        <item name="bottomNavigationStyle">@style/CustomBottomNavigation</item>
    </style>

    <style name="Theme.Muzi" parent="Base.Theme.Muzi" />

    <style name="BottomNavThemeOverlay">
        <item name="colorSecondaryContainer">@android:color/transparent</item>
        <item name="colorOnSecondaryContainer">@color/primary</item>
        <item name="android:textColorSecondary">@color/nav_inactive</item>
    </style>

    <style name="BottomNavLabelStyle">
        <item name="android:textSize">10.5sp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:translationY">-14dp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="BottomNavLabelActiveStyle" parent="BottomNavLabelStyle">
        <item name="android:textStyle">bold</item>
    </style>

    <style name="FormLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#b0ab9e</item>
        <item name="android:letterSpacing">0.07</item>
    </style>

    <style name="FormInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">11dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_gray</item>
        <item name="android:textColorHint">#b0ab9e</item>
        <item name="android:elevation">0dp</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:textCursorDrawable">@null</item>
        <item name="android:cursorVisible">true</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
    </style>

    <style name="StatBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:backgroundTint">#0D000000</item>
        <item name="android:padding">12dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="StatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">#9a7340</item>
    </style>

    <style name="StatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#7a7568</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <style name="HeroStatBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:elevation">0dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="HeroStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#1a1810</item>
    </style>

    <style name="HeroStatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#7a7568</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>

    <style name="HeroStatDivider">
        <item name="android:layout_width">1dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:layout_gravity">center_vertical</item>
        <item name="android:background">#0D000000</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MetricTab">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:paddingHorizontal">14dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:backgroundTint">#0D000000</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#7a7568</item>
    </style>

    <style name="StatBoxSmall">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_status_badge</item>
        <item name="android:padding">10dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="StatValueSmall">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="StatLabelSmall">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">9sp</item>
        <item name="android:textColor">#7a7568</item>
        <item name="android:layout_marginTop">2dp</item>
    </style>
    <style name="RoundedButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="CustomBottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconSize">20dp</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemPaddingTop">12dp</item>
        <item name="itemPaddingBottom">12dp</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>
